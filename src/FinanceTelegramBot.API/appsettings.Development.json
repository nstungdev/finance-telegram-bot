{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "FinanceTelegramBot": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss ",
        "SingleLine": true,
        "ColorBehavior": "Enabled"
      }
    }
  },
  "TelegramBot": {
    "BaseUrl": "https://api.telegram.org",
    "BotToken": "",
    "DefaultChatId": "",
    "TimeoutSeconds": 180
  }
}
